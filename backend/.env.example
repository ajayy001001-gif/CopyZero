# Server Configuration
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_URLS=http://localhost:5173

# Firebase Web API key, used for password verification via Identity Toolkit REST API
FIREBASE_WEB_API_KEY=

# Firebase Admin credentials (required in production/Render; falls back to
# firebase-service-account.json locally if these are unset)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the \n sequences literal (escaped) — do not paste a real multi-line key here.
FIREBASE_PRIVATE_KEY=

# Groq (Llama 3.1 8B Instant) — primary AI evaluation provider.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# NVIDIA NIM — not currently wired into the active AI evaluation route.
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=deepseek-ai/deepseek-v4-flash

# Optional: HuggingFace token used as an automatic fallback if Groq fails
# (timeout, rate limit, parse error). Without this set, the fallback still
# runs but degrades straight to rule-based heuristic scoring instead of
# calling HuggingFace's models.
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_CONTENT_MODEL=HuggingFaceH4/zephyr-7b-beta
