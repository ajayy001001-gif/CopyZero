rules_version = '2';

// This application is backend-only: all reads and writes go through the
// Node/Express API using the Firebase Admin SDK, which bypasses these rules
// entirely. This file exists purely as defense-in-depth so that, if a
// client-side Firestore SDK is ever misconfigured or a bug exposes the
// project's public config, direct client access is still denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
