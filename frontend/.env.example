# Backend API base URL. Required in production builds; defaults to
# http://localhost:5000 when unset.
VITE_API_URL=http://localhost:5000

# Firebase Web SDK config (public client keys — safe to expose in a browser
# bundle, but keep out of git so each environment can point at its own project).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
