VITE_FIREBASE_AUTH_DOMAIN=copyzero-fc6a0.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=copyzero-fc6a0
VITE_FIREBASE_STORAGE_BUCKET=copyzero-fc6a0.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=499888483763
VITE_FIREBASE_APP_ID=1:499888483763:web:3632589a5e93a494c42fc6
