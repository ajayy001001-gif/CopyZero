# Loaded automatically by `vite build` (production mode). These are public
# client-side values — the backend URL and Firebase web config are visible
# in the deployed bundle regardless (open devtools on any Firebase web app),
# so committing them here just means the production build works out of the
# box on any hosting platform without needing separate dashboard env var
# configuration. Actual secrets (Firebase Admin credentials, API keys for
# NIM/Groq/HuggingFace) stay backend-only and gitignored — see backend/.env.

# Production builds use same-origin `/api/*` (proxied to Render via vercel.json).
# Leave VITE_API_URL unset so requests stay on the Vercel origin and avoid CORS.
# VITE_API_URL=

